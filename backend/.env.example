# ============================================================
# Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=dev                        # dev | staging | prod
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://adminuser:adminuser_local_pw@localhost:5432/appdb
DB_SCHEMA=app
DB_POOL_MIN=3
DB_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:redis_local_pw@localhost:6379/0

# ── Auth service ─────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LLM ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# ── Blob storage ─────────────────────────────────────────────
# Azure Blob
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=rca-documents

# AWS S3 (alternative)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=rca-documents

BLOB_PROVIDER=local                # azure | s3 | local
LOCAL_BLOB_PATH=./data/blobs

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-MiniLM-L6-v2
EMBEDDING_DIM=384
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Feature flags ────────────────────────────────────────────
ENABLE_METRICS=false               # Prometheus metrics
MULTI_TENANT_ENABLED=false
ENABLE_DOCS=true                   # FastAPI /docs — disable in prod

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LLM=20/minute

# ── Session store ────────────────────────────────────────────
SESSION_STORE_PATH=/tmp/rca_sessions.db
